# Public Firebase client config (safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Local dev: path to gitignored service account file (see secrets/)
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json

# Vercel / CI: full JSON string (single line) — do not commit
FIREBASE_SERVICE_ACCOUNT_JSON=

# Platform URLs
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

NEXT_PUBLIC_APPLY_URL=/apply
NEXT_PUBLIC_OVERVIEW_URL=/overview
NEXT_PUBLIC_TAKE_HOME_REPO_URL=https://github.com/hult-cohort/admissions-task-board-fall26

# GitHub org webhook (ballot feed)
GITHUB_WEBHOOK_SECRET=
