# Platform URLs
# Production deploy: https://site-nine-rouge-68.vercel.app (alias: https://hult-cohort.vercel.app when linked)
NEXT_PUBLIC_SITE_URL=https://site-nine-rouge-68.vercel.app
# Optional: hostname shown in legal copy (defaults to program name on *.vercel.app)
# NEXT_PUBLIC_SITE_DISPLAY_HOST=cohort.hult.edu
NEXT_PUBLIC_COHORT_REPO=rogerSuperBuilderAlpha/hult-cohort-program
NEXT_PUBLIC_COHORT_ORG=rogerSuperBuilderAlpha
COHORT_ID=fall26

# Public Firebase client config (safe to expose in browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only — never NEXT_PUBLIC_*
FIREBASE_SERVICE_ACCOUNT_PATH=secrets/firebase-service-account.json
# Or inline JSON for Vercel:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# GitHub — server-only unless noted
# GITHUB_TOKEN required in production (written-review verification fails closed without it)
GITHUB_TOKEN=
# Dev only: skip GitHub issue title verification when GITHUB_TOKEN is unset (never use in production)
# ALLOW_UNVERIFIED_REVIEWS=true
# GITHUB_WEBHOOK_SECRET must match the org/repo webhook on the cohort submission repo
GITHUB_WEBHOOK_SECRET=

# Transactional email (same env names as pitch-rise / Ludwitt stack)
EMAIL_PROVIDER=mailgun
EMAIL_API_KEY=
EMAIL_DOMAIN=
EMAIL_FROM=cohort@ludwitt.com
EMAIL_FROM_NAME=Hult Cohort
# EU Mailgun accounts: EMAIL_API_BASE=https://api.eu.mailgun.net/v3

NEXT_PUBLIC_TAKE_HOME_REPO_URL=
